{
  "name": "local-ai-dj",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n SERVER,WEB -c cyan,magenta \"tsx watch server/index.ts\" \"vite --host 0.0.0.0\"",
    "desktop": "concurrently -n SERVER,WEB,APP -c cyan,magenta,green \"tsx watch server/index.ts\" \"vite --host 127.0.0.1\" \"electron electron/main.cjs\"",
    "server": "tsx watch server/index.ts",
    "web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "desktop:dist": "npm run build && electron-builder --win portable"
  },
  "build": {
    "appId": "studio.local-ai-dj",
    "productName": "Local AI DJ",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
